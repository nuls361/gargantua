# Frontend (safe to expose — anon key is public by design, protected by RLS)
VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-anon-key>

# NOTE: The Instantly API key and webhook secret are NOT here.
# They are set as Supabase Edge Function secrets and never reach the browser:
#   supabase secrets set INSTANTLY_API_KEY=...
#   supabase secrets set WEBHOOK_SECRET=...
